{
  "name":"MPV",
  "type":"OS",
  "path":"Custom",
  
  "version":"2.1.0",
  "description":"MPV Module for Chataigne",
  "url":"https://github.com/EmerickH/MPV-Chataigne",
  "downloadURL":"https://github.com/EmerickH/MPV-Chataigne/archive/refs/heads/main.zip",

  "hasInput":true,
  "hasOutput":true, 

  "hideDefaultCommands":false,
  
  "defaults":
  {	

  },

  "parameters":
  {

  },

  "hideDefaultParameters": [ ],

  "scripts": 
  [
    "moduleScript.js"
  ],

  "values":
  {

  },

  "commands":
  {
    
    "Seek":
    {
      "menu":"",  
      "callback":"seek",
      "parameters":
      {
        "Value":
        {
          "type":"Float",
          "min":0,
          "max":100000,
          "default":0
        }
      }
    },
    "Load file":
    {
      "menu":"",  
      "callback":"load",
      "parameters":
      {
        "Value":
        {
          "type":"String"
        }
      }
    },
    "Command":
    {
      "menu":"",  
      "callback":"command",
      "parameters":
      {
	"Command": {
		"type":"Enum",
		"options":{
			"Play": "play",
			"Pause": "pause",
		}
	}
      }
    },
    "Custom command":
    {
      "menu":"",
      "callback":"customCommand",
      "parameters":
      {
        "Command": {
                "type":"String",
        }
      }
    }
  }
}
